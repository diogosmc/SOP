# COPILOTO — variáveis de ambiente
# Copie para .env e ajuste conforme necessário.
# cp .env.example .env

APP_NAME=COPILOTO
APP_ENV=development
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO
SQLALCHEMY_ECHO=false

# Backend (Fase 03)
APP_HOST=0.0.0.0
APP_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8000
TIMEZONE=America/Sao_Paulo

# PostgreSQL (Docker — serviço copiloto_postgres)
POSTGRES_USER=copiloto
POSTGRES_PASSWORD=change_me_secure_password
POSTGRES_DB=copiloto
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://copiloto:change_me_secure_password@localhost:5432/copiloto

# Redis (Docker — serviço copiloto_redis)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# Ollama (Fase 07)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL_FAST=qwen3:4b
OLLAMA_MODEL_MAIN=mistral:7b
OLLAMA_MODEL_EMBED=nomic-embed-text
OLLAMA_CONTEXT_SIZE=2048
OLLAMA_KEEP_ALIVE=10m
OLLAMA_TIMEOUT_SECONDS=45

# Fase 22 — Auth / JWT (troque JWT_SECRET_KEY em produção)
AUTH_ENABLED=false
JWT_SECRET_KEY=change_me_jwt_secret_key_min_32_chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30
COOKIE_SECURE=false
RATE_LIMIT_ENABLED=true
CACHE_ENABLED=true

# Telegram Instructor (Fase 12)
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_ID=123456789

# Conversation Brain / Telegram (V1.5 / V1.5.1)
TELEGRAM_RESPONSE_MODE=hybrid
TELEGRAM_LLM_TIMEOUT_SECONDS=8
TELEGRAM_LLM_WARMUP=true
TELEGRAM_FORCE_FAST_MODEL=true
TELEGRAM_STREAMING_ENABLED=true
TELEGRAM_STREAM_EDIT_INTERVAL_MS=1200
TELEGRAM_STREAM_MIN_CHARS=180
TELEGRAM_CONTEXT_MAX_CHARS=4000
TELEGRAM_RECENT_MESSAGES_LIMIT=6
TELEGRAM_MEMORY_LIMIT=3
BRAIN_RECENT_MESSAGES_LIMIT=12
BRAIN_MEMORY_LIMIT=5
BRAIN_CONTEXT_MAX_CHARS=12000

# Scheduler (Fase 13)
SCHEDULER_ENABLED=false
CHECKIN_MORNING_TIME=07:00
CHECKIN_NOON_TIME=12:00
CHECKIN_EVENING_TIME=18:00
CHECKIN_NIGHT_TIME=22:00
DAILY_SUMMARY_TIME=23:00
WEEKLY_SUMMARY_DAY=sunday
WEEKLY_SUMMARY_TIME=20:00
